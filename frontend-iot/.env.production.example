# Fichier de production du frontend React
# Copier en .env.production et adapter les URLs

# URL de l'API backend (remplacer par l'IP ou le domaine du serveur)
REACT_APP_API_URL=http://VOTRE_SERVEUR:3001/api

# URL pour Socket.IO (meme serveur que l'API)
REACT_APP_SOCKET_URL=http://VOTRE_SERVEUR:3001
